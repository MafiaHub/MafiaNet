# EditorConfig — https://editorconfig.org
# Mirrors the existing MafiaNet source style (tabs, LF) so editors stay
# consistent with .clang-format.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C/C++ sources use tabs for indentation (Allman braces, see .clang-format)
[*.{c,cpp,cc,cxx,h,hpp,hxx,inl}]
indent_style = tab
indent_size = 4
tab_width = 4

# CMake, YAML, JSON, Markdown conventionally use spaces
[*.{cmake,yml,yaml,json}]
indent_style = space
indent_size = 2

[CMakeLists.txt]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
